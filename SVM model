import numpy as np
from sklearn import datasets
from sklearn.svm import SVC

# 1. Load the Iris dataset
iris = datasets.load_iris()
X, y = iris.data, iris.target

# 2. Train the SVM Model (Linear Kernel)
model = SVC(kernel='linear')
model.fit(X, y)

print("--- SVM Prediction Tool ---")
print(f"Please enter the following 4 features: {iris.feature_names}")

try:
    # 3. Take User Input
    # Example input: 5.1, 3.5, 1.4, 0.2
    user_data = input("Enter values separated by commas: ")
    input_features = [float(i) for i in user_data.split(',')]

    # 4. Predict
    prediction = model.predict([input_features])
    result = iris.target_names[prediction][0]

    print(f"\nResult: The flower is likely a '{result.upper()}'")
except Exception as e:
    print(f"Error: Please ensure you enter 4 numerical values. {e}")


